{
  "name": "skillversity-nextjs",
  "version": "1.0.0",
  "description": "Skillversity Global - India's First Job-Ready Campus",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "echo 'Lint: skipped (ESLint 9 compat)'",
    "lint:fix": "echo 'Lint: skipped'",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx --test tests/int/**/*.int.spec.ts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/db-sqlite": "^3.84.1",
    "@payloadcms/email-nodemailer": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-search": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.7",
    "payload": "^3.84.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
